[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false

label-focused = %{T5}%{T-} %name%
label-focused-foreground = ${colors.i3}
label-focused-padding = 1

label-unfocused = %{T5}%{T-} %name%
label-unfocused-foreground = ${colors.i3}
label-unfocused-padding = ${self.label-focused-padding}

label-visible = %{T5}%{T-} %name%
label-visible-foreground = ${self.label-focused-foreground}
label-visible-padding = ${self.label-focused-padding}

label-urgent = %{T5}%{T-} %name%
label-urgent-foreground = ${colors.danger}
label-urgent-padding = ${self.label-focused-padding}
